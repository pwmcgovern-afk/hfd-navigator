# Database connection string
DATABASE_URL="postgresql://user:password@host:5432/database"
DIRECT_URL="postgresql://user:password@host:5432/database"

# Anthropic API key for AI chat assistant
ANTHROPIC_API_KEY="your-anthropic-api-key"

# Admin dashboard API key (generate with: openssl rand -hex 32)
ADMIN_API_KEY="your-admin-api-key"

# 211 Connecticut API key (register at https://register.211.org/)
API_211_KEY="your-211-api-key"

# Vercel cron secret (auto-set by Vercel, or generate with: openssl rand -hex 32)
CRON_SECRET="your-cron-secret"

# OpenAI API key — enables hybrid (keyword + semantic) search in the chat.
# When unset, the chat falls back to keyword-only search; the app still works.
# Backfill embeddings after setting this: `npm run embed:backfill`
OPENAI_API_KEY="sk-..."

# Sentry DSN — enables production error tracking on the client + server.
# When unset, the Sentry SDK is loaded but inert (no events sent).
NEXT_PUBLIC_SENTRY_DSN=""

# Optional: Sentry source-map upload (used at build time only)
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# Email used for negative-feedback alerts (optional). When unset, alerts are skipped.
ADMIN_EMAIL=""

# Resend API key for sending feedback alerts (optional).
RESEND_API_KEY=""

# Feedback alert sender override (optional). Defaults to ADMIN_EMAIL.
FEEDBACK_EMAIL=""
